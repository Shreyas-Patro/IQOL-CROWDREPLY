REDDIT_USER_AGENT=iqol-crowdreply/1.0

# Auth — session secret should be a long random string
SESSION_SECRET=change-me-to-a-long-random-string

# Admin user — only seeds the user on first run. To change the password later,
# update it directly in the DB or via a future settings page.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# LLM_PROVIDER can be: groq | gemini | openrouter
LLM_PROVIDER=gemini

# Gemini (primary)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# OpenRouter (alternative / fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FALLBACK_MODEL=google/gemini-2.0-flash-exp:free

# Groq (alternative)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

BRAND_NAME=AllDoors.in
BRAND_URL=https://alldoors.in
SCAN_INTERVAL_MINUTES=15
MIN_RELEVANCE_SCORE=6
LLM_BATCH_SIZE=5
LLM_DAILY_BUDGET=50
